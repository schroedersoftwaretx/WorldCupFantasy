# --- Datastore ---------------------------------------------------------------
# DATABASE_URL is used by the web app at runtime.
#
# Local development: point at a local Postgres instance (see DATABASE_SETUP.md).
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/worldcup_fantasy
#
# Production (Neon): use the CONNECTION POOLER URL (hostname contains "-pooler.").
# The pooler keeps connection counts low under Vercel's serverless model.
# Example pooler URL from Neon dashboard:
#   postgresql://user:pass@ep-cool-name-12345-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/worldcup_fantasy

# DIRECT_DATABASE_URL is used ONLY by `npm run migrate` (schema migrations).
# In production, set this to the DIRECT (non-pooler) Neon URL. Neon's pooler
# runs in transaction mode, which is incompatible with DDL migrations. The
# direct URL bypasses the pooler and is safe for schema changes.
# Leave blank locally — the migrator falls back to DATABASE_URL when this is unset.
# Example direct URL from Neon dashboard:
#   postgresql://user:pass@ep-cool-name-12345.us-east-2.aws.neon.tech/neondb?sslmode=require
DIRECT_DATABASE_URL=

# --- Stats provider: football-data.org (RECOMMENDED for 2026 WC) -----------
# Free plan at football-data.org covers the FIFA World Cup including 2026.
# Register at https://www.football-data.org/client/register to get a free key.
# When set, this provider takes precedence over API_FOOTBALL_KEY below.
FOOTBALL_DATA_KEY=
# Override defaults only if needed:
# FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
# FOOTBALL_DATA_COMPETITION=WC
# FOOTBALL_DATA_SEASON=2026

# --- Stats provider: api-sports.io / API-Football (paid, fallback) ----------
# API-Football free plan only covers seasons up to 2024 — requires a paid
# plan for 2026 World Cup data. Only needed if FOOTBALL_DATA_KEY is unset.
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=

# --- Tournament identifiers (API-Football only) ------------------------------
WORLDCUP_LEAGUE_ID=1
WORLDCUP_SEASON=2026

# --- Ingest tuning -----------------------------------------------------------
# Max retry attempts on transient HTTP failures (network errors, 429, 5xx).
INGEST_HTTP_MAX_RETRIES=4
# Base delay (ms) for exponential backoff between retries.
INGEST_HTTP_BACKOFF_BASE_MS=500
# Minimum delay (ms) between sequential calls to the live provider. Provider
# free tiers are rate-limited to ~10 req/min; raise this if you hit 429s.
INGEST_HTTP_MIN_INTERVAL_MS=6500

# --- Projected points: The Odds API ------------------------------------------
# Free tier: 500 requests/month. Sign up at https://the-odds-api.com
# When set, the cron fetches match odds for upcoming WC fixtures (cached 3h)
# and computes projected fantasy points per player for the draft board.
ODDS_API_KEY=
# Override only if needed:
# ODDS_API_BASE_URL=https://api.the-odds-api.com
# ODDS_API_SPORT=soccer_fifa_world_cup
# ODDS_CACHE_HOURS=3

# --- Mock provider (offline development / tests) -----------------------------
# When set, the CLI uses FixtureMockProvider reading from this directory
# instead of hitting the live API. Required to be unset for production ingest.
# MOCK_FIXTURES_DIR=./test/fixtures/provider

# --- Firebase Authentication (web app, phase W2) -----------------------------
# Sign-in is Google via Firebase. See FIREBASE_SETUP.md for how to obtain
# every value below. The web app runs without these set, but sign-in (and so
# every page) is unavailable until they are filled in.
#
# Client SDK config - safe to expose to the browser (NEXT_PUBLIC_ prefix).
# From Firebase console -> Project settings -> Your apps -> Web app -> SDK setup.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
#
# Admin SDK service account - SECRET, server-only, never exposed to the browser.
# From Firebase console -> Project settings -> S